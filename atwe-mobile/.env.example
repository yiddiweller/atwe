# Copy to `.env` for local development.
# EXPO_PUBLIC_* vars are inlined into the client bundle at build time.

# Base URL of the existing Atwe backend (Express on Railway).
# Production: https://atwe.com
# Local backend: http://localhost:3000  (use your machine's LAN IP on a physical device, e.g. http://192.168.1.20:3000)
EXPO_PUBLIC_API_URL=https://atwe.com
