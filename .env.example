# ─── Core ───────────────────────────────────────────────
# Anthropic API key (required for chat)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Server port (optional, defaults to 3000)
PORT=3000

# Public base URL of the app — used to build links in emails (prod: https://atwe.com)
APP_URL=http://localhost:3000

# ─── Database (required for auth, history, projects, admin) ───
# On Railway, attach a PostgreSQL plugin and reference its DATABASE_URL.
DATABASE_URL=postgres://user:pass@host:5432/dbname
# Force SSL on/off. Omit to auto-detect (on for remote, off for localhost).
# Socket-style URLs (host=/path) need this set explicitly.
# DB_SSL=true

# ─── Auth ───────────────────────────────────────────────
# Secret used to sign auth JWTs (required in production — long random string)
JWT_SECRET=change-me-to-a-long-random-string
# Email auto-granted admin dashboard access (also auto email-verified)
ADMIN_EMAIL=you@company.com
# Set to 'true' to block sign-in until the email is verified (default: off)
# REQUIRE_EMAIL_VERIFICATION=false

# ─── Admin subdomain ────────────────────────────────────
# Host that serves the admin dashboard at its root (default admin.atwe.com)
ADMIN_HOST=admin.atwe.com

# ─── Email (optional — verification & password reset) ───
# If unset, emails are logged to the server console instead of sent.
# To enable real sending on atwe.com: set these in Railway, point MAIL_FROM at a
# verified atwe.com sender, and add the provider's SPF/DKIM DNS records.
#
# Recommended provider: Resend (free tier ~3,000/mo). After verifying the
# atwe.com domain in Resend, use these exact values — no mailbox needed, you can
# send from any address on the verified domain:
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend
#   SMTP_PASS=<your Resend API key>
#   MAIL_FROM=Atwe <alerts@atwe.com>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-smtp-password
MAIL_FROM=Atwe AI <no-reply@atwe.com>
# Optional: replies to automated mail (sent from a send-only From like alerts@)
# go here — e.g. your human inbox, team@atwe.com.
MAIL_REPLY_TO=team@atwe.com
# Where the in-app support/contact form is delivered (default support@atwe.com)
SUPPORT_EMAIL=support@atwe.com

# ─── Billing (optional — Stripe Checkout for Pro) ───────
# If unset, "Upgrade to Pro" uses the demo instant-upgrade path.
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Calls / WebRTC TURN (optional) ─────────────────────
# STUN is always on. Add a TURN provider so voice & video calls connect
# reliably across networks and firewalls. Priority: Cloudflare → static → free
# public relay fallback. With none set, calls still work via the public relay.
#
# Preferred: Cloudflare Realtime TURN (free 1 TB/mo). Create a TURN key in the
# Cloudflare dashboard (Realtime → TURN) and set these two — the server mints
# short-lived credentials automatically.
CLOUDFLARE_TURN_KEY_ID=your-cloudflare-turn-key-id
CLOUDFLARE_TURN_API_TOKEN=your-cloudflare-turn-api-token
#
# Alternative: a static TURN server (metered.ca / Twilio / self-hosted coturn).
# TURN_URL accepts a comma-separated list of turn:/turns: URLs.
TURN_URL=turn:your-turn-host:3478
TURN_USERNAME=your-turn-username
TURN_CREDENTIAL=your-turn-credential
