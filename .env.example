# Anthropic API key (required for chat)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Server port (optional, defaults to 3000)
PORT=3000

# PostgreSQL connection string (required for auth, history, projects, admin).
# On Railway, attach a PostgreSQL plugin and reference its DATABASE_URL.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Force SSL on/off for the DB connection. Omit to auto-detect
# (SSL on for remote hosts, off for localhost).
# DB_SSL=true

# Secret used to sign auth JWTs (required in production — use a long random string)
JWT_SECRET=change-me-to-a-long-random-string

# Email that is automatically granted admin dashboard access on signup.
ADMIN_EMAIL=you@company.com
